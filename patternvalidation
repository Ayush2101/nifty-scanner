# ── Indicator functions ───────────────────────────────────────
def calc_rsi(series, p=14):
    d  = series.diff()
    g  = d.clip(lower=0); l = -d.clip(upper=0)
    ag = g.ewm(alpha=1/p, min_periods=p).mean()
    al = l.ewm(alpha=1/p, min_periods=p).mean()
    rs = ag / al.replace(0, np.nan)
    return 100 - 100/(1+rs)

def calc_macd(series):
    e12 = series.ewm(span=12, adjust=False).mean()
    e26 = series.ewm(span=26, adjust=False).mean()
    m   = e12 - e26
    s   = m.ewm(span=9, adjust=False).mean()
    return m, s, m - s

def calc_stoch(df, k=14, d=3):
    lk = df["Low"].rolling(k).min()
    hk = df["High"].rolling(k).max()
    sk = ((df["Close"]-lk)/(hk-lk).replace(0, np.nan))*100
    return sk, sk.rolling(d).mean()

def calc_mfi(df, p=14):
    tp  = (df["High"]+df["Low"]+df["Close"])/3
    mfv = tp * df["Volume"]
    pos = mfv.where(tp > tp.shift(1), 0)
    neg = mfv.where(tp < tp.shift(1), 0)
    return 100 - 100/(1 + pos.rolling(p).sum() /
                       neg.rolling(p).sum().replace(0, np.nan))

def calc_obv(df):
    return (np.sign(df["Close"].diff()) * df["Volume"]).cumsum()

def calc_cmf(df, p=20):
    hl  = df["High"] - df["Low"]
    mfv = ((df["Close"] - df["Low"] - (df["High"] - df["Close"])) /
            hl.replace(0, np.nan)) * df["Volume"]
    return mfv.rolling(p).sum() / df["Volume"].rolling(p).sum()

def calc_bb(series, p=20, s=2):
    mid = series.rolling(p).mean()
    std = series.rolling(p).std()
    upper = mid + s*std
    lower = mid - s*std
    width = (upper - lower) / mid.replace(0, np.nan)
    return upper, mid, lower, width

# ── Validate one event ────────────────────────────────────────
def validate_event(event):
    sym          = event["symbol"]
    rally_start  = pd.Timestamp(event["rally_start"])
    name         = event["name"]

    # Fetch 90 days before rally start to have enough indicator history
    fetch_start  = (rally_start - pd.Timedelta(days=90)).strftime("%Y-%m-%d")
    fetch_end    = (rally_start + pd.Timedelta(days=5)).strftime("%Y-%m-%d")

    try:
        raw = yf.download(sym, start=fetch_start, end=fetch_end,
                          interval="1d", auto_adjust=True, progress=False)
        if raw is None or len(raw) < 30:
            return {"name": name, "status": "NO DATA", **{k: None for k in _indicator_keys()}}
        raw.columns = [c[0] if isinstance(c, tuple) else c for c in raw.columns]
        df = raw[["Open","High","Low","Close","Volume"]].dropna().copy()

        # Compute all indicators
        df["RSI"]                      = calc_rsi(df["Close"])
        df["MACD"],df["MSIG"],df["MH"] = calc_macd(df["Close"])
        df["SK"], df["SD"]             = calc_stoch(df)
        df["MFI"]                      = calc_mfi(df)
        df["OBV"]                      = calc_obv(df)
        df["CMF"]                      = calc_cmf(df)
        df["BBU"],df["BBM"],df["BBL"],df["BBW"] = calc_bb(df["Close"])
        df["EMA21"]                    = df["Close"].ewm(span=21, adjust=False).mean()
        df["EMA55"]                    = df["Close"].ewm(span=55, adjust=False).mean()
        df["VOL_RATIO"]                = df["Volume"] / df["Volume"].rolling(20).mean()
        df["OBV_SLOPE15"]              = df["OBV"].diff(15)
        df["PRICE_SLOPE15"]            = df["Close"].diff(15)
        df.dropna(inplace=True)

        # Find the row closest to rally start date
        available_dates = df.index
        closest_date    = available_dates[available_dates <= rally_start]
        if len(closest_date) == 0:
            return {"name": name, "status": "DATE MISS", **{k: None for k in _indicator_keys()}}

        row      = df.loc[closest_date[-1]]
        prev_row = df.iloc[df.index.get_loc(closest_date[-1]) - 1] if len(df) > 1 else row

        close    = float(row["Close"])
        rsi      = float(row["RSI"])
        sk       = float(row["SK"])
        mfi      = float(row["MFI"])
        cmf      = float(row["CMF"])
        bb_width = float(row["BBW"]) * 100
        obv_sl   = float(row["OBV_SLOPE15"])
        price_sl = float(row["PRICE_SLOPE15"])
        vr       = float(row["VOL_RATIO"])
        ema21    = float(row["EMA21"])
        ema55    = float(row["EMA55"])
        macd     = float(row["MACD"])
        msig     = float(row["MSIG"])

        # 52W stats from available data
        w52_high = float(df["Close"].max())
        w52_low  = float(df["Close"].min())
        pct_low  = (close - w52_low)  / w52_low  * 100
        pct_high = (close - w52_high) / w52_high * 100

        # OBV divergence check
        obv_rising      = obv_sl > 0
        price_pct_move  = abs(price_sl) / close * 100
        obv_divergence  = obv_rising and price_pct_move < 8

        # RSI state at rally start
        rsi_min10 = float(df["RSI"].tail(10).min()) if len(df) >= 10 else rsi
        mfi_min10 = float(df["MFI"].tail(10).min()) if len(df) >= 10 else mfi
        bb_sqz_d  = int((df["BBW"].tail(15) * 100 < 7).sum()) if len(df) >= 15 else 0

        actual_date = str(closest_date[-1].date())

        return {
            "name"          : name,
            "status"        : "OK",
            "actual_date"   : actual_date,
            "close"         : round(close, 2),
            # ── ACTUAL indicator values at rally start ────────
            "RSI"           : round(rsi, 1),
            "RSI_min10d"    : round(rsi_min10, 1),
            "Stoch_K"       : round(sk, 1),
            "MFI"           : round(mfi, 1),
            "MFI_min10d"    : round(mfi_min10, 1),
            "CMF"           : round(cmf, 3),
            "BB_Width_pct"  : round(bb_width, 1),
            "BB_Sqz_Days"   : bb_sqz_d,
            "Vol_Ratio"     : round(vr, 2),
            "OBV_Divergence": "YES" if obv_divergence else "NO",
            "Pct_From_Low"  : round(pct_low, 1),
            "Pct_From_High" : round(pct_high, 1),
            "P_vs_EMA21_pct": round((close/ema21 - 1)*100, 1),
            "EMA21_vs_EMA55": round((ema21/ema55 - 1)*100, 1),
            "MACD_positive" : "YES" if macd > msig else "NO",
            # ── Gain info ─────────────────────────────────────
            "gain_pct"      : event["gain_pct"],
            "trigger"       : event["trigger"],
        }

    except Exception as e:
        return {"name": name, "status": f"ERROR: {e}", **{k: None for k in _indicator_keys()}}

def _indicator_keys():
    return ["actual_date","close","RSI","RSI_min10d","Stoch_K","MFI","MFI_min10d",
            "CMF","BB_Width_pct","BB_Sqz_Days","Vol_Ratio","OBV_Divergence",
            "Pct_From_Low","Pct_From_High","P_vs_EMA21_pct","EMA21_vs_EMA55",
            "MACD_positive","gain_pct","trigger"]

# ── Run all validations ───────────────────────────────────────
def run_validation(progress_cb=None):
    results = []
    for i, event in enumerate(RALLY_EVENTS):
        if progress_cb:
            progress_cb(i, len(RALLY_EVENTS), event["name"])
        res = validate_event(event)
        results.append(res)
    return pd.DataFrame(results)

# ── Summarise: find common pattern ────────────────────────────
def find_common_pattern(df):
    """
    For each indicator, find:
    - The actual range of values across all stocks at rally start
    - How many stocks had the indicator in 'bullish' zone
    """
    ok = df[df["status"] == "OK"].copy()
    if ok.empty:
        return {}

    n = len(ok)
    summary = {}

    checks = {
        "RSI < 50"              : ok["RSI"] < 50,
        "RSI < 45"              : ok["RSI"] < 45,
        "RSI < 40"              : ok["RSI"] < 40,
        "RSI Min10d < 40"       : ok["RSI_min10d"] < 40,
        "RSI Min10d < 35"       : ok["RSI_min10d"] < 35,
        "Stoch K < 30"          : ok["Stoch_K"] < 30,
        "Stoch K < 25"          : ok["Stoch_K"] < 25,
        "Stoch K < 20"          : ok["Stoch_K"] < 20,
        "MFI < 40"              : ok["MFI"] < 40,
        "MFI < 35"              : ok["MFI"] < 35,
        "MFI < 30"              : ok["MFI"] < 30,
        "MFI Min10d < 30"       : ok["MFI_min10d"] < 30,
        "CMF < 0"               : ok["CMF"] < 0,
        "CMF < -0.05"           : ok["CMF"] < -0.05,
        "BB Width < 10%"        : ok["BB_Width_pct"] < 10,
        "BB Width < 8%"         : ok["BB_Width_pct"] < 8,
        "BB Width < 6%"         : ok["BB_Width_pct"] < 6,
        "Vol Ratio < 1.0"       : ok["Vol_Ratio"] < 1.0,
        "Vol Ratio 1.0-1.8"     : (ok["Vol_Ratio"]>=1.0) & (ok["Vol_Ratio"]<1.8),
        "OBV Divergence"        : ok["OBV_Divergence"] == "YES",
        "Within 30% of Low"     : ok["Pct_From_Low"] < 30,
        "Within 20% of Low"     : ok["Pct_From_Low"] < 20,
        "Within 10% of Low"     : ok["Pct_From_Low"] < 10,
        "30%+ below High"       : ok["Pct_From_High"] < -30,
        "20%+ below High"       : ok["Pct_From_High"] < -20,
        "Price below EMA21"     : ok["P_vs_EMA21_pct"] < 0,
        "EMA21 below EMA55"     : ok["EMA21_vs_EMA55"] < 0,
        "MACD bearish"          : ok["MACD_positive"] == "NO",
    }

    rows = []
    for label, mask in checks.items():
        count    = int(mask.sum())
        hit_rate = count / n * 100
        rows.append({
            "Condition"   : label,
            "Stocks Hit"  : f"{count}/{n}",
            "Hit Rate %"  : round(hit_rate, 0),
            "Verdict"     : (
                "✅ CONFIRMED" if hit_rate >= 70 else
                "🟡 PARTIAL"  if hit_rate >= 50 else
                "❌ WEAK"
            )
        })

    return pd.DataFrame(rows).sort_values("Hit Rate %", ascending=False)
